---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const SITE_TITLE = 'Free Website Audit | CC3PO';
const SITE_DESCRIPTION = 'Get a comprehensive website audit covering SEO, security, performance, and accessibility. Free analysis by CC3PO AI village. Expert-reviewed, no technical jargon. 15+ years experience.';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = '/images/cc3po-logo.png';
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:title" content={SITE_TITLE} />
  <meta property="og:description" content={SITE_DESCRIPTION} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="CC3PO Audit" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={SITE_TITLE} />
  <meta name="twitter:description" content={SITE_DESCRIPTION} />
  <meta name="twitter:image" content={ogImage} />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "Free Website Audit",
    description: "Comprehensive website analysis covering SEO, security, performance, and accessibility",
    url: canonicalURL,
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web-based",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock"
    },
    provider: {
      "@type": "Organization",
      name: "CC3PO",
      url: "https://cc3po.com"
    }
  })} />
</head>
<body>
  <Header />

  <!-- Hero Section -->
  <section class="hero" id="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <div class="hero-badge">
          <span class="badge-dot"></span>
          Free Website Audit
        </div>
        <h1>Is Your Website <span class="gradient-text">Leaving Money on the Table?</span></h1>
        <p class="hero-subtitle">Expert-reviewed audit covering SEO, security, performance, and accessibility — no technical jargon, just clear priorities.</p>

        <!-- Quick Hero Form -->
        <form id="auditHeroForm" class="hero-form">
          <div class="hero-form-row">
            <input type="text" name="name" required placeholder="Your name" />
            <input type="url" name="website" required placeholder="https://yourwebsite.com" />
            <input type="email" name="email" required placeholder="you@company.com" />
            <button type="submit" class="hero-submit">Get Audit →</button>
          </div>
          <p class="hero-form-note">Free. No spam. Report delivered in 24–48 hours.</p>
        </form>
        <div id="auditHeroSuccess" style="display:none;padding:16px;background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.2);border-radius:12px;margin-top:12px;">
          <p style="color:#22c55e;font-weight:600;">✓ Audit request received!</p>
          <p style="color:#a1a1aa;font-size:14px;margin-top:4px;">We'll review your site and deliver your report within 24–48 hours. Check your email for confirmation.</p>
        </div>
      </div>

      <!-- Visual Report Mockup -->
      <div class="hero-visual">
        <div class="report-mockup">
          <div class="mockup-header">
            <div class="mockup-dots">
              <span></span><span></span><span></span>
            </div>
            <span class="mockup-title">Audit Report — yoursite.com</span>
          </div>
          <div class="mockup-body">
            <div class="mockup-scores">
              <div class="mockup-score">
                <svg viewBox="0 0 36 36"><circle cx="18" cy="18" r="15.9155" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="3"/><circle cx="18" cy="18" r="15.9155" fill="none" stroke="#4cc9f0" stroke-width="3" stroke-dasharray="78, 100" stroke-linecap="round"/></svg>
                <span class="ms-val">78</span>
                <span class="ms-label">SEO</span>
              </div>
              <div class="mockup-score">
                <svg viewBox="0 0 36 36"><circle cx="18" cy="18" r="15.9155" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="3"/><circle cx="18" cy="18" r="15.9155" fill="none" stroke="#4ade80" stroke-width="3" stroke-dasharray="92, 100" stroke-linecap="round"/></svg>
                <span class="ms-val">92</span>
                <span class="ms-label">Security</span>
              </div>
              <div class="mockup-score">
                <svg viewBox="0 0 36 36"><circle cx="18" cy="18" r="15.9155" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="3"/><circle cx="18" cy="18" r="15.9155" fill="none" stroke="#fbbf24" stroke-width="3" stroke-dasharray="65, 100" stroke-linecap="round"/></svg>
                <span class="ms-val">65</span>
                <span class="ms-label">Speed</span>
              </div>
              <div class="mockup-score">
                <svg viewBox="0 0 36 36"><circle cx="18" cy="18" r="15.9155" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="3"/><circle cx="18" cy="18" r="15.9155" fill="none" stroke="#f472b6" stroke-width="3" stroke-dasharray="85, 100" stroke-linecap="round"/></svg>
                <span class="ms-val">85</span>
                <span class="ms-label">A11y</span>
              </div>
            </div>
            <div class="mockup-findings">
              <div class="mf-row">
                <span class="mf-pill high">High</span>
                <span class="mf-text">Optimize images — 2.3MB savings</span>
              </div>
              <div class="mf-row">
                <span class="mf-pill medium">Medium</span>
                <span class="mf-text">Add missing alt text (12 images)</span>
              </div>
              <div class="mf-row">
                <span class="mf-pill low">Low</span>
                <span class="mf-text">Enable browser caching</span>
              </div>
            </div>
          </div>
          <div class="mockup-glow"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="trust-bar" aria-label="Trust signals">
    <div class="trust-inner">
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        <span class="trust-label">Expert-Reviewed</span>
      </div>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
        <span class="trust-label">No Technical Jargon</span>
      </div>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span class="trust-label">24–48 Hour Turnaround</span>
      </div>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
        <span class="trust-label">15+ Years Experience</span>
      </div>
    </div>
  </section>

  <!-- What We Check -->
  <section class="what-we-check" id="what-we-check">
    <div class="section-header">
      <span class="section-tag">Coverage</span>
      <h2>What We Check</h2>
      <p class="section-subtitle">Four critical areas that directly impact your traffic, conversions, and compliance.</p>
    </div>
    <div class="check-grid">
      <div class="check-card" data-category="seo">
        <div class="check-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        </div>
        <h3>SEO Analysis</h3>
        <ul>
          <li>Meta tags &amp; page structure</li>
          <li>Keyword optimization</li>
          <li>Mobile friendliness</li>
          <li>Core Web Vitals</li>
          <li>Schema markup</li>
        </ul>
      </div>
      <div class="check-card" data-category="security">
        <div class="check-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </div>
        <h3>Security Check</h3>
        <ul>
          <li>SSL certificate status</li>
          <li>HTTPS enforcement</li>
          <li>Vulnerability scan</li>
          <li>Plugin &amp; dependency security</li>
          <li>Form &amp; data protection</li>
        </ul>
      </div>
      <div class="check-card" data-category="performance">
        <div class="check-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <h3>Performance</h3>
        <ul>
          <li>Page load speed</li>
          <li>Image &amp; asset optimization</li>
          <li>Caching configuration</li>
          <li>Script efficiency</li>
          <li>Server response time</li>
        </ul>
      </div>
      <div class="check-card" data-category="accessibility">
        <div class="check-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
        </div>
        <h3>Accessibility</h3>
        <ul>
          <li>WCAG compliance</li>
          <li>Screen reader compatibility</li>
          <li>Color contrast ratios</li>
          <li>Keyboard navigation</li>
          <li>Alt text &amp; ARIA labels</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="how-it-works" id="how-it-works">
    <div class="section-header">
      <span class="section-tag">Process</span>
      <h2>How It Works</h2>
      <p class="section-subtitle">From URL to actionable insights in three simple steps.</p>
    </div>
    <div class="steps-wrap">
      <div class="step-card">
        <div class="step-num">1</div>
        <div class="step-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
        </div>
        <h3>Submit Your URL</h3>
        <p>Enter your website address and email. Optionally tell us what matters most.</p>
      </div>
      <div class="step-connector">
        <svg viewBox="0 0 80 24" fill="none"><path d="M0 12h70M62 4l8 8-8 8" stroke="rgba(255,255,255,0.12)" stroke-width="2"/></svg>
      </div>
      <div class="step-card">
        <div class="step-num">2</div>
        <div class="step-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </div>
        <h3>AI + Expert Analysis</h3>
        <p>Our AI village scans your site across 16+ checkpoints, then an expert reviews the findings.</p>
      </div>
      <div class="step-connector">
        <svg viewBox="0 0 80 24" fill="none"><path d="M0 12h70M62 4l8 8-8 8" stroke="rgba(255,255,255,0.12)" stroke-width="2"/></svg>
      </div>
      <div class="step-card">
        <div class="step-num">3</div>
        <div class="step-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <h3>Get Your Report</h3>
        <p>Receive a clear, prioritized report with exact fixes — no fluff, no jargon.</p>
      </div>
    </div>
  </section>

  <!-- Report Preview -->
  <section class="report-preview-section" id="report-preview">
    <div class="section-header">
      <span class="section-tag">Deliverable</span>
      <h2>What You'll Receive</h2>
      <p class="section-subtitle">A clean, actionable report you can share with your team or developer.</p>
    </div>
    <div class="report-preview-card">
      <div class="rp-header">
        <div class="rp-logo">
          <img src="/images/cc3po-logo.png" alt="CC3PO" />
          <span>CC3PO Audit Report</span>
        </div>
        <span class="rp-site">yoursite.com</span>
      </div>
      <div class="rp-scores">
        <div class="rp-score" data-cat="seo">
          <div class="rp-ring">
            <svg viewBox="0 0 36 36"><circle cx="18" cy="18" r="15.9155" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="3"/><circle cx="18" cy="18" r="15.9155" fill="none" stroke="#4cc9f0" stroke-width="3" stroke-dasharray="78, 100" stroke-linecap="round"/></svg>
            <span class="rp-val">78</span>
          </div>
          <span class="rp-label">SEO</span>
        </div>
        <div class="rp-score" data-cat="security">
          <div class="rp-ring">
            <svg viewBox="0 0 36 36"><circle cx="18" cy="18" r="15.9155" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="3"/><circle cx="18" cy="18" r="15.9155" fill="none" stroke="#f72585" stroke-width="3" stroke-dasharray="92, 100" stroke-linecap="round"/></svg>
            <span class="rp-val">92</span>
          </div>
          <span class="rp-label">Security</span>
        </div>
        <div class="rp-score" data-cat="performance">
          <div class="rp-ring">
            <svg viewBox="0 0 36 36"><circle cx="18" cy="18" r="15.9155" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="3"/><circle cx="18" cy="18" r="15.9155" fill="none" stroke="#4ade80" stroke-width="3" stroke-dasharray="65, 100" stroke-linecap="round"/></svg>
            <span class="rp-val">65</span>
          </div>
          <span class="rp-label">Performance</span>
        </div>
        <div class="rp-score" data-cat="accessibility">
          <div class="rp-ring">
            <svg viewBox="0 0 36 36"><circle cx="18" cy="18" r="15.9155" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="3"/><circle cx="18" cy="18" r="15.9155" fill="none" stroke="#fb923c" stroke-width="3" stroke-dasharray="85, 100" stroke-linecap="round"/></svg>
            <span class="rp-val">85</span>
          </div>
          <span class="rp-label">Accessibility</span>
        </div>
      </div>
      <div class="rp-findings">
        <div class="rp-findings-header">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <span>Top Priority Fixes</span>
        </div>
        <div class="rp-finding-row">
          <span class="rp-pill high">High</span>
          <span class="rp-finding-text">Optimize images — 2.3MB savings potential</span>
          <span class="rp-finding-meta">Performance</span>
        </div>
        <div class="rp-finding-row">
          <span class="rp-pill medium">Medium</span>
          <span class="rp-finding-text">Add missing alt text to 12 images</span>
          <span class="rp-finding-meta">Accessibility</span>
        </div>
        <div class="rp-finding-row">
          <span class="rp-pill medium">Medium</span>
          <span class="rp-finding-text">Enable browser caching for static assets</span>
          <span class="rp-finding-meta">Performance</span>
        </div>
        <div class="rp-finding-row">
          <span class="rp-pill low">Low</span>
          <span class="rp-finding-text">Add Open Graph meta tags for social sharing</span>
          <span class="rp-finding-meta">SEO</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials" id="testimonials">
    <div class="section-header">
      <span class="section-tag">Results</span>
      <h2>What Our Clients Say</h2>
      <p class="section-subtitle">Real feedback from real business owners.</p>
    </div>
    <div class="testimonials-grid">
      <div class="testimonial-card">
        <div class="testimonial-stars">★★★★★</div>
        <p class="testimonial-text">"The audit revealed issues we didn't even know existed. After fixing the performance problems, our load time dropped from 8 seconds to under 2."</p>
        <div class="testimonial-author">
          <div class="author-avatar" style="background: linear-gradient(135deg, #4cc9f0, #4361ee);">M</div>
          <div class="author-info">
            <strong>Matt S.</strong>
            <span>Business Owner, mattsafdari.com</span>
          </div>
        </div>
      </div>
      <div class="testimonial-card">
        <div class="testimonial-stars">★★★★★</div>
        <p class="testimonial-text">"Finally someone who explains technical issues in plain English. The prioritized action list made it easy to know exactly what to fix first."</p>
        <div class="testimonial-author">
          <div class="author-avatar" style="background: linear-gradient(135deg, #f72585, #b5179e);">K</div>
          <div class="author-info">
            <strong>Karen R.</strong>
            <span>Marketing Director, Sacramento</span>
          </div>
        </div>
      </div>
      <div class="testimonial-card">
        <div class="testimonial-stars">★★★★★</div>
        <p class="testimonial-text">"The accessibility audit helped us avoid potential lawsuits and made our site usable for all customers. Truly invaluable service."</p>
        <div class="testimonial-author">
          <div class="author-avatar" style="background: linear-gradient(135deg, #4ade80, #22c55e);">J</div>
          <div class="author-info">
            <strong>James T.</strong>
            <span>E-commerce Store Owner, Bay Area</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Full Form Section -->
  <section class="full-form-section" id="audit-form">
    <div class="section-header">
      <span class="section-tag">Get Started</span>
      <h2>Request Your Free Audit</h2>
      <p class="section-subtitle">Want to add more detail? Fill out the full form below. Or use the quick form at the top.</p>
    </div>
    <form id="auditFullForm" class="audit-form">
      <div class="form-row">
        <div class="form-group">
          <label for="name">Your Name *</label>
          <input type="text" id="name" name="name" required placeholder="John Smith" />
        </div>
        <div class="form-group">
          <label for="email-full">Email Address *</label>
          <input type="email" id="email-full" name="email" required placeholder="john@example.com" />
        </div>
      </div>
      <div class="form-group">
        <label for="website-full">Website URL *</label>
        <input type="url" id="website-full" name="website" required placeholder="https://yourwebsite.com" />
      </div>
      <div class="form-group">
        <label for="focus">Primary Focus (Optional)</label>
        <select id="focus" name="focus">
          <option value="">Select a focus area...</option>
          <option value="seo">SEO &amp; Search Rankings</option>
          <option value="security">Security &amp; Protection</option>
          <option value="performance">Speed &amp; Performance</option>
          <option value="accessibility">Accessibility &amp; Compliance</option>
          <option value="all">Complete Overview</option>
        </select>
      </div>
      <div class="form-group">
        <label for="message">Additional Details (Optional)</label>
        <textarea id="message" name="message" rows="4" placeholder="Tell us about your website, any specific concerns, or what you'd like us to focus on..."></textarea>
      </div>
      <button type="submit" class="submit-button">
        <span>Submit Audit Request</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </button>
    </form>
    <div id="auditFullSuccess" style="display:none;padding:24px;background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.2);border-radius:16px;margin-top:20px;">
      <h3 style="color:#22c55e;margin-bottom:8px;">✓ Audit request received!</h3>
      <p style="color:#a1a1aa;">We'll review your site and deliver your report within 24–48 hours. Check your email for confirmation.</p>
      <p style="color:#71717a;font-size:13px;margin-top:12px;">Next steps:</p>
      <ol style="color:#a1a1aa;font-size:14px;margin-left:16px;margin-top:8px;">
        <li>Confirmation email sent to your inbox</li>
        <li>Our team reviews your website</li>
        <li>Detailed report delivered within 24–48 hours</li>
      </ol>
    </div>
  </section>

  <Footer />
  <script type="module">
    import { submitAuditRequest } from '/js/lead-capture.js';

    const heroForm = document.getElementById('auditHeroForm');
    const heroSuccess = document.getElementById('auditHeroSuccess');
    heroForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(heroForm);
      try {
        await submitAuditRequest({
          name: fd.get('name'),
          email: fd.get('email'),
          website: fd.get('website')
        }, 'audit-cc3po-hero');
        heroForm.style.display = 'none';
        heroSuccess.style.display = 'block';
      } catch (err) {
        console.error('Audit submission error:', err);
        alert('Something went wrong. Please try again or email us at info@cc3po.com');
      }
    });

    const fullForm = document.getElementById('auditFullForm');
    const fullSuccess = document.getElementById('auditFullSuccess');
    fullForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(fullForm);
      try {
        await submitAuditRequest({
          name: fd.get('name'),
          email: fd.get('email'),
