---
const navLinks = [
	{ href: 'https://cc3po.com', label: 'Home' },
	{ href: 'https://offers.cc3po.com/our-services.html', label: 'Services' },
	{ href: 'https://insights.cc3po.com/blog', label: 'Blog' },
	{ href: '/', label: 'Free Audit' },
];
---

<style>
	nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		height: 70px;
		background: rgba(10, 10, 11, 0.9);
		backdrop-filter: blur(20px);
		display: flex;
		align-items: center;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		z-index: 1000;
	}
	nav .inner {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 24px;
		width: 100%;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	nav .logo {
		font-size: 22px;
		font-weight: 800;
		background: linear-gradient(135deg, #fff, #a78bfa, #00d2ff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		text-decoration: none;
	}
	nav ul {
		display: flex;
		gap: 28px;
		list-style: none;
	}
	nav ul a {
		color: #a1a1aa;
		font-size: 14px;
		text-decoration: none;
		transition: color 0.2s;
	}
	nav ul a:hover {
		color: #fff;
	}
	nav ul a.active {
		color: #6b35ff;
	}
	.nav-cta {
		background: linear-gradient(135deg, #6b35ff, #00d2ff);
		padding: 10px 20px;
		border-radius: 25px;
		color: #fff;
		font-size: 13px;
		font-weight: 600;
		text-decoration: none;
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.nav-cta:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 15px rgba(107, 53, 255, 0.4);
	}
	.nav-toggle {
		display: none;
		flex-direction: column;
		gap: 5px;
		cursor: pointer;
		padding: 10px;
		position: absolute;
		right: 24px;
	}
	.nav-toggle span {
		width: 24px;
		height: 2px;
		background: #fff;
		transition: all 0.3s;
	}
	.mobile-menu {
		display: none;
		position: fixed;
		top: 70px;
		left: 0;
		right: 0;
		background: rgba(10, 10, 11, 0.98);
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		padding: 20px;
		flex-direction: column;
		gap: 0;
		z-index: 999;
	}
	.mobile-menu.active {
		display: flex;
	}
	.mobile-menu a {
		display: block;
		padding: 14px 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		color: #a1a1aa;
		font-size: 16px;
		text-decoration: none;
	}
	@media (max-width: 768px) {
		nav .nav-links {
			display: none;
		}
		.nav-toggle {
			display: flex;
		}
	}
</style>

<nav>
	<div class="inner">
		<a href="https://cc3po.com" class="logo">CC3PO</a>
		<ul class="nav-links">
			{navLinks.map(link => (
				<li>
					<a href={link.href} class:list={[Astro.url.pathname === link.href && 'active']}>
						{link.label}
					</a>
				</li>
			))}
		</ul>
		<a href="#audit-form" class="nav-cta">Get Free Audit</a>
	</div>
	<div class="nav-toggle" id="nav-toggle">
		<span></span>
		<span></span>
		<span></span>
	</div>
</nav>
<div class="mobile-menu" id="mobile-menu">
	{navLinks.map(link => (
		<a href={link.href}>{link.label}</a>
	))}
	<a href="#audit-form" style="color: #6b35ff; font-weight: 600;">Get Free Audit</a>
</div>

<script>
	document.getElementById('nav-toggle')?.addEventListener('click', () => {
		document.getElementById('mobile-menu')?.classList.toggle('active');
	});
</script>