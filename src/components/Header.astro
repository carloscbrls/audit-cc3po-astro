---
const navLinks = [
	{ href: 'https://cc3po.com', label: 'Home' },
	{ href: 'https://offers.cc3po.com/our-services.html', label: 'Services' },
	{ href: 'https://insights.cc3po.com/blog', label: 'Blog' },
	{ href: 'https://docs.cc3po.com', label: 'Docs' },
	{ href: '/', label: 'Free Audit' },
];
---

<style>
	nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		height: 70px;
		background: rgba(10, 10, 11, 0.9);
		backdrop-filter: blur(20px);
		display: flex;
		align-items: center;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		z-index: 1000;
	}
	nav .inner {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 24px;
		width: 100%;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	nav .logo {
		text-decoration: none;
	}
	nav .logo img {
		height: 45px;
		width: auto;
	}
	nav ul {
		display: flex;
		gap: 28px;
		list-style: none;
	}
	nav ul a {
		color: #a1a1aa;
		font-size: 14px;
		text-decoration: none;
		transition: color 0.2s;
	}
	nav ul a:hover {
		color: #fff;
	}
	nav ul a.active {
		color: #6b35ff;
	}
	.nav-cta {
		background: linear-gradient(135deg, #6b35ff, #00d2ff);
		padding: 10px 20px;
		border-radius: 25px;
		color: #fff;
		font-size: 13px;
		font-weight: 600;
		text-decoration: none;
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.nav-cta:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 15px rgba(107, 53, 255, 0.4);
	}
	.nav-toggle {
		display: none;
		flex-direction: column;
		justify-content: space-between;
		width: 28px;
		height: 20px;
		cursor: pointer;
		padding: 4px;
		margin-left: auto;
		background: transparent;
		border: none;
	}
	.nav-toggle span {
		display: block;
		width: 100%;
		height: 2px;
		background: #fff;
		transition: all 0.3s ease;
		transform-origin: center;
	}
	.nav-toggle.active span:nth-child(1) {
		transform: translateY(9px) rotate(45deg);
	}
	.nav-toggle.active span:nth-child(2) {
		opacity: 0;
	}
	.nav-toggle.active span:nth-child(3) {
		transform: translateY(-9px) rotate(-45deg);
	}
	.mobile-menu {
		display: none;
		position: fixed;
		top: 70px;
		left: 0;
		right: 0;
		background: rgba(10, 10, 11, 0.98);
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		padding: 20px;
		flex-direction: column;
		gap: 0;
		z-index: 999;
	}
	.mobile-menu.active {
		display: flex;
	}
	.mobile-menu a {
		display: block;
		padding: 14px 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		color: #a1a1aa;
		font-size: 16px;
		text-decoration: none;
	}
	.mobile-menu a:hover {
		color: #fff;
	}
	@media (max-width: 768px) {
		nav .nav-links {
			display: none;
		}
		.nav-toggle {
			display: flex;
		}
	}
</style>

<nav>
	<div class="inner">
		<a href="https://cc3po.com" class="logo">
			<img src="https://cc3po.com/wp-content/uploads/2023/02/White-logo-no-background-scaled.png" alt="CC3PO" />
		</a>
		<ul class="nav-links">
			{navLinks.map(link => (
				<li>
					<a href={link.href} class:list={[Astro.url.pathname === link.href && 'active']}>
						{link.label}
					</a>
				</li>
			))}
		</ul>
		<a href="#audit-form" class="nav-cta">Get Free Audit</a>
	</div>
	<div class="nav-toggle" id="nav-toggle">
		<span></span>
		<span></span>
		<span></span>
	</div>
</nav>
<div class="mobile-menu" id="mobile-menu">
	{navLinks.map(link => (
		<a href={link.href}>{link.label}</a>
	))}
	<a href="#audit-form" style="background: linear-gradient(135deg, #6b35ff, #00d2ff); color: #fff; text-align: center; border-radius: 8px; margin-top: 12px; padding: 14px;">Get Free Audit</a>
</div>

<script>
	const toggle = document.getElementById('nav-toggle');
	const mobileMenu = document.getElementById('mobile-menu');
	
	toggle?.addEventListener('click', () => {
		toggle.classList.toggle('active');
		mobileMenu?.classList.toggle('active');
	});
	
	document.querySelectorAll('.mobile-menu a').forEach(link => {
		link.addEventListener('click', () => {
			toggle?.classList.remove('active');
			mobileMenu?.classList.remove('active');
		});
	});
</script>